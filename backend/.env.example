# ── AI Provider ──────────────────────────────────────────────────────────────
# Set to "claude" (default) or "gemini"
AI_PROVIDER=claude

# ── Anthropic (used when AI_PROVIDER=claude) ──────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Google Gemini (used when AI_PROVIDER=gemini) ──────────────────────────────
# Free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Try gemini-1.5-flash if gemini-2.0-flash is unavailable on your key tier
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── Vapi Voice AI ─────────────────────────────────────────────────────────────
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=
VAPI_PHONE_NUMBER_ID=

# ── Resend (email) ───────────────t─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ── Server (Go backend) ───────────────────────────────────────────────────────
PORT=8080
DB_PATH=./kyron.db
